# Security headers applied by the Workers Static Assets layer for every
# static route. The /api/* routes get the same suite from worker/index.ts
# (secureAssetResponse / jsonResponse). scripts/test-worker-security-headers.ts
# asserts this file's CSP stays byte-identical to the worker's
# CONTENT_SECURITY_POLICY constant — update both together or CI fails.
#
# Rationale: on env deploys the assets edge path serves static routes without
# invoking the Worker (run_worker_first glob was not honored for non-API
# paths), so header enforcement must live at the asset layer itself. Found by
# scripts/staging-smoke-test.mjs against the deployed staging origin.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https: http://localhost:* http://127.0.0.1:*; media-src 'self' blob:; worker-src 'self' blob:
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
