{
  // Cook Anything — static export + Cooking Companion API on Cloudflare Workers.
  // Phase 0 containment: hosted execution is fail-closed and explicitly off.
  // Browser BYOK still works because those calls go directly to the provider.
  // Do not set this to "true" until Phase 1 trust-boundary, sandboxing,
  // rate-limiting, session ownership, and privacy controls are complete.
  "vars": { "HOSTED_COMPANION_ENABLED": "false" },
  // Companion backends (see docs/AI-ASSISTANT.md + docs/VPS-BRIDGE.md):
  //   BYOK (default) — users connect their own key in the UI.
  //   Subscription bridge — requires HOSTED_COMPANION_ENABLED="true" plus
  //     COMPANION_UPSTREAM_TOKEN and a configured upstream/origin.
  //   Hosted key — requires HOSTED_COMPANION_ENABLED="true" plus
  //     `wrangler secret put ANTHROPIC_API_KEY`.
  // "vars": {
  //   "HOSTED_COMPANION_ENABLED": "true",
  //   "COMPANION_UPSTREAM": "https://companion-bridge.robofox.online"
  // },
  // Quick-tunnel mode may publish its current trycloudflare origin to this KV
  // under key "origin", but origin publication is rejected while Phase 0 is on.
  "kv_namespaces": [
    { "binding": "COMPANION_CONFIG", "id": "6ff2aa2e59384dd18a512e455f2b682b" }
  ],
  "name": "cook-anything",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "routes": [
    { "pattern": "cook-anything.robofox.online", "custom_domain": true }
  ],
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  }
}
