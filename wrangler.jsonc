{
  // Cook Anything — static export + Cooking Companion API on Cloudflare Workers.
  // Companion backends (see docs/AI-ASSISTANT.md + docs/VPS-BRIDGE.md):
  //   BYOK (default, zero config) — users connect their own key in the UI.
  //   Subscription bridge — uncomment "vars" below once the VPS bridge is up,
  //     and `wrangler secret put COMPANION_UPSTREAM_TOKEN`.
  //   Hosted key — `wrangler secret put ANTHROPIC_API_KEY`.
  // "vars": { "COMPANION_UPSTREAM": "https://companion-bridge.robofox.online" },
  // Subscription bridge via quick tunnel: bridge/tunnel script on the VPS
  // publishes its current trycloudflare origin to this KV under key "origin".
  "kv_namespaces": [
    { "binding": "COMPANION_CONFIG", "id": "6ff2aa2e59384dd18a512e455f2b682b" }
  ],
  "name": "cook-anything",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "routes": [
    { "pattern": "cook-anything.robofox.online", "custom_domain": true }
  ],
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  }
}
