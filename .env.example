# Phase 5 optional portable kitchen.
# Leave both unset to keep Cook Anything fully local-only.
# Use only the Supabase publishable/anon browser key. Never put service_role here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Legacy Supabase projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
# Do not set both unless they refer to the same public browser credential.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
